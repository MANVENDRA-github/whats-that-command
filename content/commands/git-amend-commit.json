{
  "id": "git-amend-commit",
  "command": "git commit --amend --no-edit",
  "description": "Add currently staged changes into the previous commit without changing its message",
  "tool": "git",
  "category": "undo",
  "tags": [
    "fix last commit",
    "forgot to add",
    "tack on",
    "edit previous"
  ],
  "example": "git add forgotten.js && git commit --amend --no-edit",
  "danger": false,
  "related": [
    "git-amend-message",
    "git-undo-last-commit"
  ]
}
