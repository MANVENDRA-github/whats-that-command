{
  "id": "git-amend-message",
  "command": "git commit --amend -m \"new message\"",
  "description": "Rewrite the message of the previous commit",
  "tool": "git",
  "category": "undo",
  "tags": [
    "fix typo in commit",
    "rename commit",
    "change message",
    "rewrite message"
  ],
  "example": "git commit --amend -m \"fix: correct payment rounding\"",
  "danger": false,
  "related": [
    "git-amend-commit"
  ]
}
