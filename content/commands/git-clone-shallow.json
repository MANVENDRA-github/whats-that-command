{
  "id": "git-clone-shallow",
  "command": "git clone --depth=1 <url>",
  "description": "Clone only the latest commit instead of the full history — much faster for large repos",
  "tool": "git",
  "category": "setup",
  "tags": [
    "quick clone",
    "skip history",
    "fast download",
    "minimal copy",
    "just the latest"
  ],
  "example": "git clone --depth=1 https://github.com/user/repo.git",
  "danger": false,
  "related": [
    "git-submodule-update"
  ]
}
