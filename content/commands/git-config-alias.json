{
  "id": "git-config-alias",
  "command": "git config --global alias.<short> \"<command>\"",
  "description": "Create a personal shortcut for a long or frequently-used git command",
  "tool": "git",
  "category": "setup",
  "tags": [
    "custom shortcut",
    "shorthand",
    "save typing",
    "personal abbreviation"
  ],
  "example": "git config --global alias.lg \"log --oneline --graph --all\"",
  "danger": false,
  "related": [
    "git-log-graph"
  ]
}
