{
  "id": "git-worktree-add",
  "command": "git worktree add <path> <branch>",
  "description": "Check out a branch into a separate directory so you can work on two branches at once",
  "tool": "git",
  "category": "branch",
  "tags": [
    "two branches at once",
    "parallel work",
    "side checkout",
    "without switching"
  ],
  "example": "git worktree add ../hotfix release-1.2",
  "danger": false,
  "related": [
    "git-new-branch",
    "git-switch-branch"
  ]
}
